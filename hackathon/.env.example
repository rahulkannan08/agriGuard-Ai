# ========== AgriVision Environment Configuration ==========
# Copy this file to .env and fill in your values

# ========== LLM Configuration (NVIDIA NIM API) ==========
# Get your FREE API key from: https://build.nvidia.com/
# 1. Sign in with NVIDIA account (or create one free)
# 2. Go to any model page, e.g., https://build.nvidia.com/meta/llama-3_1-70b-instruct
# 3. Click "Get API Key" - copy the key starting with "nvapi-"
NVIDIA_API_KEY=nvapi-your_api_key_here
LLM_MODEL=meta/llama-3.1-70b-instruct

# Alternative models (uncomment to use):
# LLM_MODEL=meta/llama-3.1-8b-instruct      # Faster, good quality
# LLM_MODEL=meta/llama-3.2-3b-instruct      # Fastest, acceptable quality

# ========== Application Settings ==========
DEBUG=true
APP_NAME=AgriVision
APP_VERSION=1.0.0

# ========== Server Settings ==========
HOST=0.0.0.0
PORT=8000

# ========== Model Settings ==========
MODEL_PATH=model/model.h5
CLASS_LABELS_PATH=model/class_labels.json

# ========== Validation Thresholds ==========
BLUR_THRESHOLD=100.0
CONFIDENCE_THRESHOLD=0.60
MAX_IMAGE_SIZE_MB=10

# ========== Optional: Weather API (Nice-to-have) ==========
# OPENWEATHER_API_KEY=your_key_here

# ========== Optional: Fallback LLM (Groq) ==========
# GROQ_API_KEY=your_groq_key_here
