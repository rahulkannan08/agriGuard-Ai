# Server
PORT=8000
NODE_ENV=development

# NVIDIA API (Required for LLM recommendations)
NVIDIA_API_KEY=nvapi-your_key_here
LLM_MODEL=meta/llama-3.1-70b-instruct
LLM_PROVIDER=gemini

# Gemini API (Used by Ask AI About This Result)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY_1=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2

# LiveKit (voice chat)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
DEEPGRAM_API_KEY=your_deepgram_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=your_default_multilingual_voice_id
ELEVENLABS_VOICE_ID_TAMIL=your_tamil_voice_id
ELEVENLABS_VOICE_ID_KANNADA=your_kannada_voice_id

# ML Service (if using Python microservice instead of mock)
ML_SERVICE_URL=http://localhost:8001
USE_MOCK_ML=true
USE_EXTERNAL_AI=false

# Validation
BLUR_THRESHOLD=100
CONFIDENCE_THRESHOLD=0.60
MAX_IMAGE_SIZE_MB=10
